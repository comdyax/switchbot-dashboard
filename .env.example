# ── Database (shared by db, ble-scanner, backend) ───────────────────────────
POSTGRES_USER=switchbot
POSTGRES_PASSWORD=change-me
POSTGRES_DB=switchbot

# Host interface the Postgres port binds to. Use 127.0.0.1 to keep the DB
# reachable only from localhost; 0.0.0.0 exposes it on the network.
POSTGRES_BIND_IP=127.0.0.1

# Host path where Postgres stores its data (bind-mounted into the container).
POSTGRES_DATA_PATH=./pgdata

# Connection string. Inside Compose the scanner reaches the DB on the host
# network (localhost), the backend reaches it via the `db` service name.
# Compose substitutes the POSTGRES_* values above into these
# — it's shown for running services standalone (outside Compose):
# DATABASE_URL=postgresql://switchbot:change-me@localhost:5432/switchbot

# ── BLE scanner ─────────────────────────────────────────────────────────────
# JSON map of sensor MAC address → display name. MACs must be uppercase.
BLE_DEVICES={"E1:23:45:67:89:AB": "Room 1", "E1:23:45:67:89:CD": "Room 2"}

# Seconds between scan cycles (each cycle scans ~10s). Default: 600 (10 min).
BLE_SCAN_INTERVAL=600

# ── Backend ─────────────────────────────────────────────────────────────────
# Comma-separated allowed origins for the API (CORS). Needed only for the Vite
# dev server, which calls the API cross-origin; in production nginx proxies
# /api same-origin, so no CORS is required.
CORS_ORIGINS=http://localhost:5173

# ── Frontend ────────────────────────────────────────────────────────────────
# Host port the dashboard (nginx) is published on. Default: 8080.
FRONTEND_PORT=8080
